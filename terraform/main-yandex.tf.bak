# Get latest Ubuntu 22.04 image
data "yandex_compute_image" "ubuntu" {
  family = "ubuntu-2204-lts"
}

# Compute Instance (VM)
resource "yandex_compute_instance" "lab_vm" {
  name        = var.vm_name
  hostname    = var.vm_name
  platform_id = "standard-v2"
  zone        = var.zone

  resources {
    cores         = 2
    memory        = 1
    core_fraction = 20  # 20% CPU - free tier
  }

  boot_disk {
    initialize_params {
      image_id = data.yandex_compute_image.ubuntu.id
      size     = 10
      type     = "network-hdd"
    }
  }

  network_interface {
    subnet_id = yandex_vpc_subnet.lab_subnet.id
    nat       = true # Assign public IP
    # security_group_ids = [yandex_vpc_security_group.lab_sg.id]  # Commented out
  }

  metadata = {
    ssh-keys = "${var.vm_user}:${file(var.ssh_public_key_path)}"
  }

  scheduling_policy {
    preemptible = false
  }
}
