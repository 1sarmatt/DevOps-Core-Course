# Yandex Cloud Terraform Configuration
# Lab 4 - Infrastructure as Code

terraform {
  required_providers {
    yandex = {
      source  = "yandex-cloud/yandex"
      version = "~> 0.100"
    }
  }
  required_version = ">= 1.0"
}

# Provider configuration
provider "yandex" {
  service_account_key_file = var.service_account_key_file
  cloud_id                 = var.cloud_id
  folder_id                = var.folder_id
  zone                     = var.zone
}

# VPC Network
resource "yandex_vpc_network" "lab_network" {
  name        = "lab-network"
  description = "Network for DevOps Lab 4"
}

# Subnet
resource "yandex_vpc_subnet" "lab_subnet" {
  name           = "lab-subnet"
  description    = "Subnet for DevOps Lab 4"
  v4_cidr_blocks = ["10.128.0.0/24"]
  zone           = var.zone
  network_id     = yandex_vpc_network.lab_network.id
}

# Security Group (commented out - requires vpc.admin role)
# Uncomment if you add vpc.admin role to service account
